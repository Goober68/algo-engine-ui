# Copy to `.env.local` and edit. .env.local is gitignored.
#
# Set this to point the UI at a running algo-coord. When unset, the UI
# falls back to mock mode and serves from /fixtures/.
#
# Local dev:  VITE_ALGO_COORD_URL=http://localhost:8090
# VPS:        VITE_ALGO_COORD_URL=http://192.168.1.203:8090
VITE_ALGO_COORD_URL=
