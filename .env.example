# Copy to `.env.local` and edit. .env.local is gitignored.
#
# Set this to point the UI at a running algo-coord. When unset, the UI
# falls back to mock mode and serves from /fixtures/.
#
# Local dev:  VITE_ALGO_COORD_URL=http://localhost:8090
# VPS:        VITE_ALGO_COORD_URL=http://192.168.1.203:8090
VITE_ALGO_COORD_URL=

# OPTIONAL: tick-archive sidecar URL. Used by the per-trade tick modal
# as a fallback when coord's in-memory ring buffer doesn't cover the
# trade's time window (i.e. the trade is older than ~4 hours). Today
# the archive lives on AlgoGuy at E:\TickData; the sidecar there
# serves the same /tick_history shape as coord. Leave blank to disable
# the fallback (modal will just say "no ticks in window" for older
# trades).
#
# Local dev:  VITE_TICK_ARCHIVE_URL=http://192.168.1.17:8091
VITE_TICK_ARCHIVE_URL=
